# ============================================
# 卡域支付服务环境变量配置
# ============================================
# 复制本文件为 .env 并填入实际值

# --- 服务配置 ---
PORT=3001
NODE_ENV=production

# --- Supabase 配置 ---
# 从 Supabase 控制台 > Settings > API 获取
SUPABASE_URL=https://xybpcsmjjcnkjwfsuder.supabase.co
# service_role 密钥（用于服务端操作，切勿暴露到前端）
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- 支付宝配置 ---
# 开放平台 > 我的应用 获取
ALIPAY_APP_ID=2021000000000000
# 应用私钥（PKCS8 格式，不含头尾标记）
ALIPAY_APP_PRIVATE_KEY=MIIEvQIBADANB...
# 支付宝公钥
ALIPAY_PUBLIC_KEY=MIIBIjANB...
# 签名类型
ALIPAY_SIGN_TYPE=RSA2
# 网关地址（沙箱用 https://openapi-sandbox.dl.alipaydev.com/gateway.do）
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# 异步通知地址（部署后的服务器公网地址）
ALIPAY_NOTIFY_URL=https://your-domain.com/api/notify/alipay
# 同步返回地址
ALIPAY_RETURN_URL=https://your-domain.com/payment-result.html

# --- 微信支付配置 ---
# 商户号
WECHAT_MCH_ID=1900000000
# API v3 密钥
WECHAT_API_V3_KEY=your_32_char_api_v3_key_here
# 商户证书序列号
WECHAT_CERT_SERIAL_NO=your_cert_serial_no
# 商户私钥（apiclient_key.pem 内容，不含头尾）
WECHAT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# 微信支付平台证书（apiclient_cert.pem 内容，用于验签）
WECHAT_PLATFORM_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# 异步通知地址
WECHAT_NOTIFY_URL=https://your-domain.com/api/notify/wechat
# AppID（公众号/小程序/移动应用）
WECHAT_APP_ID=wx0000000000000000

# --- 业务配置 ---
# 平台手续费率（需与 DB platform_config 一致）
PLATFORM_FEE_RATE=0.03
# 自动确认天数
AUTO_CONFIRM_DAYS=7
